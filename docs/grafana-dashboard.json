{
  "title": "RapidEMS — operations",
  "uid": "rapidems-ops",
  "tags": ["rapidems"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Active dispatches",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "rapidems_active_dispatches" }],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Pending emergencies",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "rapidems_pending_emergencies" }],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Available ambulances",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "rapidems_available_ambulances" }],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Hospitals on diversion",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [{ "expr": "rapidems_hospitals_on_diversion" }],
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Dispatch latency (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(rapidems_dispatch_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(rapidems_dispatch_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(rapidems_dispatch_seconds_bucket[5m])))", "legendFormat": "p99" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "type": "timeseries",
      "title": "Dispatch rate by severity",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (severity) (rate(rapidems_dispatch_total[5m]))", "legendFormat": "SEV-{{severity}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate by status class",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (status) (rate(rapidems_http_requests_total[5m]))", "legendFormat": "{{status}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p95 by route",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (route, le) (rate(rapidems_http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{route}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
    },
    {
      "type": "timeseries",
      "title": "LLM calls by provider",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (provider, outcome) (rate(rapidems_llm_calls_total[5m]))", "legendFormat": "{{provider}} {{outcome}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 }
    },
    {
      "type": "timeseries",
      "title": "LLM latency p95",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(rapidems_llm_latency_seconds_bucket[5m])))", "legendFormat": "{{provider}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 }
    },
    {
      "type": "timeseries",
      "title": "Routing provider success rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (provider, outcome) (rate(rapidems_routing_calls_total[5m]))", "legendFormat": "{{provider}} {{outcome}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 }
    },
    {
      "type": "timeseries",
      "title": "Routing fallback rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "rate(rapidems_routing_fallback_total[5m])", "legendFormat": "haversine fallback" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 }
    }
  ]
}
