# =============================================================
# AI Emergency Response System — Environment Configuration
# Copy this file to .env. Defaults work out of the box.
# =============================================================

# ---- Database ----
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./emergency.db
# To use PostgreSQL instead:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/emergency

# ---- Security ----
SECRET_KEY=change-me-in-production-please-use-a-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- App ----
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# ---- ML models ----
MODELS_DIR=./ai_models
ALLOW_HEURISTIC_FALLBACK=true

# ---- LLM extraction (optional, free tiers) ----
# Caller transcript -> structured intake form. Empty keys = feature disabled,
# system falls back to heuristic regex skim.
# Groq:   https://console.groq.com/keys      (Llama 3.3 70B, ~30 RPM free)
# Gemini: https://aistudio.google.com/apikey (gemini-1.5-flash, ~15 RPM free)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
LLM_PROVIDER_ORDER=groq,gemini

# ---- Road routing (optional, all free tier) ----
# Chain: OSRM (self-hosted, unlimited) -> ORS (2000/day) -> HERE (250K/month)
# -> haversine. Empty keys are skipped.
# OSRM:  https://github.com/Project-OSRM/osrm-backend  (Docker, India .osm.pbf)
# ORS:   https://openrouteservice.org/dev/
# HERE:  https://platform.here.com/  (free 250K req/month)
OSRM_URL=
ORS_API_KEY=eyJvcmciOiI1YjNjZTM1OTc4NTExMTAwMDFjZjYyNDgiLCJpZCI6IjIyMTRmMTA1MDk3ZjQyNGRhNjJlZDc3YmMwMzYzMTY4IiwiaCI6Im11cm11cjY0In0=
MAPBOX_API_KEY=
HERE_API_KEY=abkq1wrZd77EocoWIPL-nE9f1pPq_Kat6puwHQpjrfk
# Blend: final_eta = ETA_ROAD_WEIGHT * road_eta + (1 - w) * ml_eta
ETA_ROAD_WEIGHT=0.7

# ---- Notifications (optional, all free tier) ----
# Telegram (instant, free, no rate limit). Make a bot via @BotFather, paste
# the token here, then have users /start the bot to register.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# SMTP — Gmail App Password (free) or SendGrid free tier (100/day).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=
SMTP_FROM_NAME=RapidEMS

# Twilio (paid, optional). Real SMS path; off unless all three are set.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ---- Seed data ----
SEED_ON_STARTUP=true
SEED_CITY_LAT=19.0760
SEED_CITY_LNG=72.8777
SEED_NUM_AMBULANCES=20
SEED_NUM_HOSPITALS=8

# ---- Default admin ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@emergency.example.com
